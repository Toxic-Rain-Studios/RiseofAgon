msgid "name_task_1"
msgstr "基础战斗"

msgid "short_desc_task_1"
msgstr "测试你的技能,对战当地的哥布林,在Agon世界开始你的旅程!"

msgid "short_desc_task_1_stage_1"
msgstr "杀死10个哥布林."

msgid "desc_task_1_stage_1"
msgstr "你起始城市附近的哥布林数量增加了,去测试你对这些敌人的勇气吧!杀死10个哥布林来获得你的奖励."

msgid "short_desc_task_1_stage_2"
msgstr "杀死50个哥布林."

msgid "desc_task_1_stage_2"
msgstr "哥布林又回来惹麻烦了,需要教训! 再杀50个哥布林来获得你的奖励."

msgid "short_desc_task_1_stage_3"
msgstr "杀死100个哥布林."

msgid "desc_task_1_stage_3"
msgstr "是时候全力以赴,认真对付哥布林了!  再杀100个哥布林来获得你的奖励."

msgid "name_task_2"
msgstr "基础收获"

msgid "short_desc_task_2"
msgstr "使用我们在背包中提供的工具,从 Agon周围的矿区收集各种资源."

msgid "short_desc_task_2_stage_1"
msgstr "收获10种草药."

msgid "desc_task_2_stage_1"
msgstr "阿贡有很多资源可以收获.让我们用镰刀从附近的灌木丛中收集一些大天使,白莓,地狱草和蛇草."

msgid "short_desc_task_2_stage_2"
msgstr "收获10块木材."

msgid "desc_task_2_stage_2"
msgstr "现在你应该拿起一把木斧,开始砍一些树来收集10块木材."

msgid "short_desc_task_2_stage_3"
msgstr "收获10块石头."

msgid "desc_task_2_stage_3"
msgstr "接下来我们寻找岩石,这样我们就可以使用鹤嘴锄收集一些石头."

msgid "short_desc_task_2_stage_4"
msgstr "收获10个铁矿石."

msgid "desc_task_2_stage_4"
msgstr "铁是一种非常宝贵的资源,用于制作各种物品,包括武器和盔甲.使用鹤嘴锄从金属矿区收集10块铁."

msgid "short_desc_task_2_stage_5"
msgstr "收获10条鱼."

msgid "desc_task_2_stage_5"
msgstr "最后,我们前往水域.使用你的钓鱼竿收集10条鱼,你可以用它来做一些美味的食物!"

msgid "name_task_3"
msgstr "开采铁矿石"

msgid "short_desc_task_3"
msgstr "用鹤嘴锄从你找到的金属矿区开采铁矿石!"

msgid "short_desc_task_3_stage_1"
msgstr "收获20个铁矿石."

msgid "desc_task_3_stage_1"
msgstr "是时候去寻找铁矿石了,这样你就可以制造武器和盔甲.使用你的鹤嘴锄,从金属矿区开采20个铁矿石."

msgid "short_desc_task_3_stage_2"
msgstr "收获50个铁矿石."

msgid "desc_task_3_stage_2"
msgstr "继续通过从世界上的金属矿区再开采50个铁矿石来增加您的铁矿石储藏."

msgid "short_desc_task_3_stage_3"
msgstr "收获100个铁矿石."

msgid "desc_task_3_stage_3"
msgstr "再开采100个铁矿石来完成这个任务."

msgid "name_task_4"
msgstr "开采石头"

msgid "short_desc_task_4"
msgstr "用鹤嘴锄从你找到的岩石中挖掘石头!"

msgid "short_desc_task_4_stage_1"
msgstr "收获10块石头."

msgid "desc_task_4_stage_1"
msgstr "虽然石头是阿贡常见的资源之一,但它仍然用于许多配方."

msgid "short_desc_task_4_stage_2"
msgstr "收获50块石头."

msgid "desc_task_4_stage_2"
msgstr "不仅有石头用于许多配方,还可以从岩石收集其他材料."

msgid "short_desc_task_4_stage_3"
msgstr "收获100块石头."

msgid "desc_task_4_stage_3"
msgstr "从阿贡世界中发现的岩石中再开采100 块石头来增加您的初始库存."

msgid "name_task_5"
msgstr "收集草药"

msgid "short_desc_task_5"
msgstr "用你的镰刀从灌木丛中收集草药!"

msgid "short_desc_task_5_stage_1"
msgstr "收获20种草药."

msgid "desc_task_5_stage_1"
msgstr "灌木是草药的主要来源.灌木丛中有各种各样的草药,有不同的制作用途."

msgid "short_desc_task_5_stage_2"
msgstr "收获50种草药."

msgid "desc_task_5_stage_2"
msgstr "曼陀罗不仅用于制作,也大量用作法术试剂."

msgid "short_desc_task_5_stage_3"
msgstr "收获100种草药."

msgid "desc_task_5_stage_3"
msgstr "收集更多的草药永远不会有错!坐骑的草料,制作魔杖的蛇草,馅饼的浆果!还有很多例子."

msgid "name_task_6"
msgstr "砍伐木材"

msgid "short_desc_task_6"
msgstr "使用你的木斧,从各种各样的树木中收集木材."

msgid "short_desc_task_6_stage_1"
msgstr "收获20个木材."

msgid "desc_task_6_stage_1"
msgstr "木材是一种宝贵的资源.用于制作许多物品,包括武器,箭头和为船舶和玩家城市构建模块."

msgid "short_desc_task_6_stage_2"
msgstr "收获50个木材."

msgid "desc_task_6_stage_2"
msgstr "在工作台上用锯子把木头精制成木材."

msgid "short_desc_task_6_stage_3"
msgstr "收获100个木材."

msgid "desc_task_6_stage_3"
msgstr "即使你不自己制作物品,收集和销售木材是非常有利可图的交易."

msgid "name_task_7"
msgstr "钓鱼"

msgid "short_desc_task_7"
msgstr "使用钓鱼竿在水中捕获鱼!"

msgid "short_desc_task_7_stage_1"
msgstr "收获20条鱼."

msgid "desc_task_7_stage_1"
msgstr "鱼是很好的食物来源.在烤箱里使用锅碗瓢盆会产生一些美味佳肴.将鱼与其他收获的物品相结合,以获得更美味的美食!"

msgid "short_desc_task_7_stage_2"
msgstr "收获50条鱼."

msgid "desc_task_7_stage_2"
msgstr "用你的钓鱼竿从水中卷起50多条鱼."

msgid "short_desc_task_7_stage_3"
msgstr "收获100条鱼."

msgid "desc_task_7_stage_3"
msgstr "当你收集更多的鱼,你会发现在水面上有很多其他资源可以收集."

msgid "name_task_8"
msgstr "对战小妖魔"

msgid "short_desc_task_8"
msgstr "杀死那些讨厌的小妖魔, 以提高你的技能, 增加你的财富!"

msgid "short_desc_task_8_stage_1"
msgstr "杀死10个小妖魔."

msgid "desc_task_8_stage_1"
msgstr "看起来你已经发现了一些小妖魔!他们是一群讨厌的小家伙,所以尽量减少他们的数量!杀死任何10个小妖魔来获得你的奖励."

msgid "short_desc_task_8_stage_2"
msgstr "杀死50个小妖魔."

msgid "desc_task_8_stage_2"
msgstr "就像老鼠一样,更多的小妖魔已经出现,是时候杀死更多!再杀50个小妖魔来获得你的奖励."

msgid "short_desc_task_8_stage_3"
msgstr "杀死150个小妖魔."

msgid "desc_task_8_stage_3"
msgstr "摧毁小妖魔,反抗他们的同胞!再杀150个小妖魔就可以得到奖励."

msgid "name_task_9"
msgstr "对战巨魔"

msgid "short_desc_task_9"
msgstr "反击麻烦的巨魔来获得你的奖励!"

msgid "short_desc_task_9_stage_1"
msgstr "杀死10个巨魔."

msgid "desc_task_9_stage_1"
msgstr "既然你已经杀了你的第一个巨魔,是时候再杀几个了!杀死任何10个巨魔来获得你的奖励."

msgid "short_desc_task_9_stage_2"
msgstr "杀死50个巨魔."

msgid "desc_task_9_stage_2"
msgstr "巨魔没有被你最近的攻击吓倒!再杀50个巨魔来获得你的奖励."

msgid "short_desc_task_9_stage_3"
msgstr "杀死150个巨魔."

msgid "desc_task_9_stage_3"
msgstr "与巨魔战斗,毁灭他们的族人!杀死150个巨魔来获得你的奖励."

msgid "name_task_11"
msgstr "弓箭手进阶"

msgid "short_desc_task_11"
msgstr "通过提高射箭技能来提升你的角色!"

msgid "short_desc_task_11_stage_1"
msgstr "用箭击打怪物10次."

msgid "desc_task_11_stage_1"
msgstr "开始你作为一个弓箭手的旅程,用箭击中怪物10次."

msgid "short_desc_task_11_stage_2"
msgstr "用箭再打怪物50次."

msgid "desc_task_11_stage_2"
msgstr "继续你作为一个弓箭手的进阶,用箭击中怪物50次."

msgid "short_desc_task_11_stage_3"
msgstr "用箭再打怪物200次."

msgid "desc_task_11_stage_3"
msgstr "用箭再击打怪物200次,证明你的射箭技能."

msgid "name_task_12"
msgstr "新手法师"

msgid "short_desc_task_12"
msgstr "通过增加你的法师技能来提升你的角色!"

msgid "short_desc_task_12_stage_1"
msgstr "用魔法攻击怪物x10"

msgid "desc_task_12_stage_1"
msgstr "开始你作为一个法师的旅程,在一些怪物身上练习你的魔法技能!"

msgid "short_desc_task_12_stage_2"
msgstr "用魔法攻击怪物x50"

msgid "desc_task_12_stage_2"
msgstr "当你再次使用它对付怪物,进攻性的魔法会升级."

msgid "short_desc_task_12_stage_3"
msgstr "用魔法攻击怪物x200"

msgid "desc_task_12_stage_3"
msgstr "记得在你前进的过程中查看法师,看看你是否解锁了新的法术或能力!"

msgid "name_task_13"
msgstr "战士进阶"

msgid "short_desc_task_13"
msgstr "通过增加你的战士技能来提升你的角色!"

msgid "short_desc_task_13_stage_1"
msgstr "近战攻击怪物x10"

msgid "desc_task_13_stage_1"
msgstr "开始你作为一个战士的旅程,用近战武器击中怪物10次."

msgid "short_desc_task_13_stage_2"
msgstr "近战攻击怪物x50"

msgid "desc_task_13_stage_2"
msgstr "继续你作为一个战士的进程,用近战武器打怪物50次."

msgid "short_desc_task_13_stage_3"
msgstr "用近战攻击怪物x200"

msgid "desc_task_13_stage_3"
msgstr "用近战武器再打怪物200次,证明你的战士技能."

msgid "name_task_16"
msgstr "恶魔杀手"

msgid "short_desc_task_16"
msgstr "猎杀恶魔家族的怪物来完成这个任务!"

msgid "short_desc_task_16_stage_1"
msgstr "杀死50个暗影灵魂."

msgid "desc_task_16_stage_1"
msgstr "开始你的旅程,作为一个恶魔杀手杀死50个暗影灵魂."

msgid "short_desc_task_16_stage_2"
msgstr "杀死25个幽冥法王."

msgid "desc_task_16_stage_2"
msgstr "你现在需要杀死25个幽冥法王来完成这个阶段的恶魔杀戮任务."

msgid "short_desc_task_16_stage_3"
msgstr "杀死20个暗影骑士."

msgid "desc_task_16_stage_3"
msgstr "接下来杀死20个暗影骑士进入恶魔杀戮任务的最后阶段."

msgid "short_desc_task_16_stage_4"
msgstr "杀死5个恶魔."

msgid "desc_task_16_stage_4"
msgstr "结束5个恶魔的生命,完成你杀死恶魔的任务,并收获最后的奖励."

msgid "name_task_19"
msgstr "巨人杀手"

msgid "short_desc_task_19"
msgstr "狩猎巨人家族的怪物来完成这个任务!"

msgid "short_desc_task_19_stage_1"
msgstr "杀死30个食人魔恶霸"

msgid "desc_task_19_stage_1"
msgstr "作为一个巨人杀手开始你的旅程,杀死30个食人魔恶霸."

msgid "short_desc_task_19_stage_2"
msgstr "杀死10个食人魔首领."

msgid "desc_task_19_stage_2"
msgstr "你现在需要杀死10个食人魔首领来完成这个阶段的巨人杀戮任务."

msgid "short_desc_task_19_stage_3"
msgstr "杀死30个山丘巨人斯洛格."

msgid "desc_task_19_stage_3"
msgstr "摧毁30个山丘巨人斯洛格,进入巨人杀戮任务的下一阶段."

msgid "short_desc_task_19_stage_4"
msgstr "杀死25个山丘巨人克洛伯."

msgid "desc_task_19_stage_4"
msgstr "接下来杀死25个山丘巨人克洛伯进入巨人杀戮任务的最后阶段."

msgid "short_desc_task_19_stage_5"
msgstr "杀死20个巨型石魔人."

msgid "desc_task_19_stage_5"
msgstr "结束20个巨型石魔人的生命, 完成你的巨人杀戮任务任务, 并收获你最后的奖励."

msgid "name_task_21"
msgstr "马劳特杀手"

msgid "short_desc_task_21"
msgstr "猎杀马劳特家族的怪物来完成这个任务!"

msgid "short_desc_task_21_stage_1"
msgstr "杀死60个马劳特仆从或高级仆从."

msgid "desc_task_21_stage_1"
msgstr "作为一个马劳特杀手开始你的旅程,杀死 60个马劳特的仆从或高级仆从."

msgid "short_desc_task_21_stage_2"
msgstr "杀死40个马劳特助手,欺骗者."

msgid "desc_task_21_stage_2"
msgstr "摧毁40个马劳特助手, 马劳特欺骗者, 进入马劳特杀戮任务的下一阶段."

msgid "short_desc_task_21_stage_3"
msgstr "杀死15个高级暗袍."

msgid "desc_task_21_stage_3"
msgstr "接着杀死15个高级暗袍进入到下一阶段的马劳特杀戮任务."

msgid "short_desc_task_21_stage_4"
msgstr "杀死15个黑暗骑士."

msgid "desc_task_21_stage_4"
msgstr "接下来杀死15个黑暗骑士, 进入马劳特杀戮的最后阶段."

msgid "short_desc_task_21_stage_5"
msgstr "杀死20个黑暗领主."

msgid "desc_task_21_stage_5"
msgstr "结束20个黑暗领主的生命, 完成你杀戮马劳特的任务, 并收获你最后的奖励."

msgid "name_task_22"
msgstr "牛头人杀手"

msgid "short_desc_task_22"
msgstr "狩猎牛头人家族怪物完成这项任务!"

msgid "short_desc_task_22_stage_1"
msgstr "杀死30个牛头人怪兽."

msgid "desc_task_22_stage_1"
msgstr "开始你的旅程, 作为一个牛头人杀手杀死30牛头人怪兽."

msgid "short_desc_task_22_stage_2"
msgstr "杀死25个牛头人法师."

msgid "desc_task_22_stage_2"
msgstr "摧毁25个牛头人法师, 进入牛头人杀戮任务的下一阶段."

msgid "short_desc_task_22_stage_3"
msgstr "杀死20个牛头人英雄."

msgid "desc_task_22_stage_3"
msgstr "接下来杀死20个牛头人英雄, 进入牛头人杀戮任务的最后阶段."

msgid "short_desc_task_22_stage_4"
msgstr "杀死10个牛头人之王."

msgid "desc_task_22_stage_4"
msgstr "结束10个牛头人之王的生命,完成你的牛头人杀戮任务,并收获你最后的奖励."

msgid "name_task_23"
msgstr "怪物杀手"

msgid "short_desc_task_23"
msgstr "狩猎怪物家族完成这项任务!"

msgid "short_desc_task_23_stage_1"
msgstr "杀死50个阿尔塞恩."

msgid "desc_task_23_stage_1"
msgstr "开始你的旅程, 作为一个怪物杀手杀死50个阿尔塞恩,阿尔塞恩驼峰, 或双头阿尔塞恩."

msgid "short_desc_task_23_stage_2"
msgstr "杀死30个肉巨人."

msgid "desc_task_23_stage_2"
msgstr "接下来杀死 30个肉巨人, 进入怪物杀戮任务的最后阶段."

msgid "short_desc_task_23_stage_3"
msgstr "杀死25个移血者奥驰."

msgid "desc_task_23_stage_3"
msgstr "结束25个移血者奥驰的生命,完成你的怪物杀戮任务,并收获你最后的奖励."

msgid "name_task_24"
msgstr "自然杀手"

msgid "short_desc_task_24"
msgstr "狩猎自然家族怪物完成这项任务!"

msgid "short_desc_task_24_stage_1"
msgstr "杀死60个海尔希姆."

msgid "desc_task_24_stage_1"
msgstr "开始你的旅程,作为一个自然杀手杀死60个海尔希姆."

msgid "short_desc_task_24_stage_2"
msgstr "杀死40个森林先知."

msgid "desc_task_24_stage_2"
msgstr "你现在需要杀死40个森林先知来完成这个阶段的自然杀戮."

msgid "short_desc_task_24_stage_3"
msgstr "杀死30个橡树领主."

msgid "desc_task_24_stage_3"
msgstr "摧毁30个橡树领主, 进入自然杀戮任务的下一阶段."

msgid "short_desc_task_24_stage_4"
msgstr "杀死20个森林傀儡."

msgid "desc_task_24_stage_4"
msgstr "接下来杀死20个森林傀儡,进入自然杀戮任务的最后阶段."

msgid "short_desc_task_24_stage_5"
msgstr "杀死10个树魔王."

msgid "desc_task_24_stage_5"
msgstr "结束10个树魔王的生命,完成你的自然杀戮任务,并收获你最后的奖励."

msgid "name_task_26"
msgstr "骷髅杀手"

msgid "short_desc_task_26"
msgstr "狩猎骷髅家族的怪物完成这项任务!"

msgid "short_desc_task_26_stage_1"
msgstr "杀死60个脆弱骷髅,骷髅弓箭手或骷髅战士."

msgid "desc_task_26_stage_1"
msgstr "开始你的旅程,作为骷髅杀手杀死60个脆弱骷髅,骷髅弓箭手或骷髅战士."

msgid "short_desc_task_26_stage_2"
msgstr "再杀50个骷髅."

msgid "desc_task_26_stage_2"
msgstr "你现在需要杀死50个塞韦里来完成这个阶段的骷髅杀戮任务."

msgid "short_desc_task_26_stage_3"
msgstr "杀死40个墓穴守卫,坟墓领主和其他骷髅."

msgid "desc_task_26_stage_3"
msgstr "摧毁40个墓穴守卫,寿衣骑士或死眼骷髅, 进入骷髅杀戮任务的下一阶段."

msgid "short_desc_task_26_stage_4"
msgstr "杀死30个骷髅人."

msgid "desc_task_26_stage_4"
msgstr "接下来分类击杀30个骷髅人魔王,骷髅人奴隶,骷髅人士兵,骷髅人之手进入骷髅杀戮的最后阶段."

msgid "short_desc_task_26_stage_5"
msgstr "杀死25个不灭法师."

msgid "desc_task_26_stage_5"
msgstr "结束25个不灭法师的生命,完成骷髅杀戮任务,并收获最后的奖励."

msgid "name_task_29"
msgstr "火山杀手"

msgid "short_desc_task_29"
msgstr "狩猎火山家族怪物来完成这项任务!"

msgid "short_desc_task_29_stage_1"
msgstr "杀死25个火焰巨人."

msgid "desc_task_29_stage_1"
msgstr "开始你的旅程,作为一个火山杀手杀死25个火焰巨人."

msgid "short_desc_task_29_stage_2"
msgstr "杀死20个熔岩傀儡或火焰巨人."

msgid "desc_task_29_stage_2"
