msgstr "抓住熔岩巨人的挑战!"

msgid "short_desc_task_93_stage_3"
msgstr "释放你的愤怒,以赢得火焰织机的头衔!"

msgid "desc_task_93_stage_3"
msgstr "火镜巨人是下一个, 你能证明你的战斗能力吗?"

msgid "short_desc_task_93_stage_4"
