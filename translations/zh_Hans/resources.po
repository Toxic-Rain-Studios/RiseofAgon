msgid "r_Shearsword"
msgstr "剪剑"

msgid "desc_r_Shearsword"
msgstr "这种武器的刀刃两端都有一排方形的牙齿.只能用来提高基本的战斗技能."

msgid "r_Doubleblade"
msgstr "双刃剑"

