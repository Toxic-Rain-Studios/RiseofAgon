msgid "r_Gem of Accuracy"
msgstr "精确宝石"

msgid "desc_r_Gem of Accuracy"
msgstr "具有此附魔的武器会增加成功打击的几率."

msgid "r_Gem of Acid Protection"
msgstr "酸蚀防护宝石"

msgid "desc_r_Gem of Acid Protection"
msgstr "具有此附魔的盔甲将获得酸蚀防护加成."

msgid "r_Gem of Acid Weakness"
msgstr "酸蚀弱点宝石"

msgid "desc_r_Gem of Acid Weakness"
msgstr " 具有此附魔的武器除了造成伤害外,还会降低目标的酸蚀防护."

msgid "r_Gem of Agony"
msgstr "痛苦宝石"

msgid "desc_r_Gem of Agony"
msgstr "具有此附魔的武器除了造成伤害外,还可能对其目标造成折磨痛苦,给予若干战斗惩罚."

msgid "r_Gem of Air Magic"
msgstr "空气魔法宝石"

msgid "desc_r_Gem of Air Magic"
msgstr "具有此附魔的法杖将增加空气法术强度."

msgid "r_Gem of Alfarbane"
msgstr "暗法诅咒宝石"

msgid "desc_r_Gem of Alfarbane"
msgstr "具有此附魔的武器将对暗法造成额外的伤害."

msgid "r_Gem of Alteration Protection"
msgstr "蚀变防护宝石"

msgid "desc_r_Gem of Alteration Protection"
msgstr "这个附魔将增加盔甲的蚀变防护."

msgid "r_Gem of Antimagic"
msgstr "抵抗魔法宝石"

msgid "desc_r_Gem of Antimagic"
msgstr "此宝石可以使所附魔的武器减少攻击者的法术几率."

msgid "r_Gem of Arcana"
msgstr "奥秘宝石"

msgid "desc_r_Gem of Arcana"
msgstr "具有此附魔的武器会造成额外的奥术伤害."

msgid "r_Gem of Arcane Magic"
msgstr "奥术魔法宝石"

msgid "desc_r_Gem of Arcane Magic"
msgstr "具有此附魔的法杖将增加所有奥术魔法的强度."

msgid "r_Gem of Arcane Protection"
msgstr "奥术防护宝石"

msgid "desc_r_Gem of Arcane Protection"
msgstr "这个附魔将增加一块盔甲的奥术防护效果."

msgid "r_Gem of Attack Delay"
msgstr "攻击延迟宝石"

msgid "desc_r_Gem of Attack Delay"
msgstr "具有此附魔的武器除了造成伤害外,还可以减缓目标的所有攻击."

msgid "r_Gem of Bludgeoning Protection"
msgstr "棒击防护宝石"

msgid "desc_r_Gem of Bludgeoning Protection"
msgstr "这个附魔将增加盔甲的棒击防护效果."

msgid "r_Gem of Bludgeoning Weakness"
msgstr "棒击弱点宝石"

msgid "desc_r_Gem of Bludgeoning Weakness"
msgstr "具有此附魔的武器除了会造成伤害之外,还会降低其目标的棒击防护."

msgid "r_Gem of Chaos"
msgstr "混乱宝石"

msgid "desc_r_Gem of Chaos"
msgstr "这颗宝石可以会使带有迷惑法术的武器附魔."

msgid "r_Gem of Cold Protection"
msgstr "寒冷防护宝石"

msgid "desc_r_Gem of Cold Protection"
msgstr "这个附魔将增加一块盔甲的的寒冷防护能力."

msgid "r_Gem of Cold Weakness"
msgstr "寒冷弱点宝石"

msgid "desc_r_Gem of Cold Weakness"
msgstr "具有此附魔的武器除了造成伤害外,还会降低目标的寒冷防护."

msgid "r_Gem of Concussion"
msgstr "震荡宝石"

msgid "desc_r_Gem of Concussion"
msgstr "这可以增加武器的晕眩效果给它的目标若干攻击惩罚."

msgid "r_Gem of Constitution"
msgstr "体质宝石"

msgid "desc_r_Gem of Constitution"
msgstr "这个附魔增加角色的耐久值.它可以被注入到武器,盔甲或珠宝中."

msgid "r_Gem of Corrosion"
msgstr "腐蚀宝石"

msgid "desc_r_Gem of Corrosion"
msgstr "这种附魔会给武器攻击增加额外的酸蚀伤害."

msgid "r_Gem of Crippling"
msgstr "残损宝石"

msgid "desc_r_Gem of Crippling"
msgstr "具有此附魔的武器除了造成伤害外,还可能降低其目标的移动速度."

msgid "r_Gem of Decapitation"
msgstr "斩首宝石"

msgid "desc_r_Gem of Decapitation"
msgstr "具有此附魔的武器增加斩首的几率."

msgid "r_Gem of Defense"
msgstr "防御宝石"

msgid "desc_r_Gem of Defense"
msgstr "这种附魔可以增加防御值.它可以注入武器,盔甲或珠宝中. "

msgid "r_Gem of Degeneration"
msgstr "退化宝石"

msgid "desc_r_Gem of Degeneration"
msgstr "这可能会使任何武器都附魔,从而降低其命中的任何人的自然生命恢复速度."

msgid "r_Gem of Demonbane"
msgstr "恶魔诅咒宝石"

msgid "desc_r_Gem of Demonbane"
msgstr "具有此附魔的武器将对恶魔,魔鬼及其亲属造成额外伤害."

msgid "r_Gem of Dexterity"
msgstr "敏捷宝石"

msgid "desc_r_Gem of Dexterity"
msgstr "具有此附魔的物品可以增加佩戴者的敏捷性.具有此效果的多个物品不能叠加其加成."

msgid "r_Gem of Dexterity Drain"
msgstr "敏捷消耗宝石"

msgid "desc_r_Gem of Dexterity Drain"
msgstr "具有此附魔的武器除了造成伤害外,还会降低目标的敏捷度."

msgid "r_Gem of Divine Magic"
msgstr "神圣魔法宝石"

msgid "desc_r_Gem of Divine Magic"
msgstr "具有此附魔的法杖将增加所有神圣魔法的强度."

msgid "r_Gem of Dragonbane"
msgstr "龙之诅咒宝石"

msgid "desc_r_Gem of Dragonbane"
msgstr "具有此附魔的武器将对龙及龙皮造成额外的伤害."

msgid "r_Gem of Durability"
msgstr "耐久宝石"

msgid "desc_r_Gem of Durability"
msgstr "增加所附魔物品的耐久性."

msgid "r_Gem of Dwarfbane"
msgstr "矮人诅咒宝石"

msgid "desc_r_Gem of Dwarfbane"
msgstr "具有此附魔的武器将对矮人造成额外伤害."

msgid "r_Gem of Earth Magic"
msgstr "土魔法宝石"

msgid "desc_r_Gem of Earth Magic"
msgstr "具有此附魔的法杖将会增加土元素魔法法术强度."

msgid "r_Gem of Enfeeblement"
msgstr "衰弱宝石"

msgid "desc_r_Gem of Enfeeblement"
msgstr "具有此附魔的武器除了造成伤害外,还会阻挡目标所有的近战攻击."

msgid "r_Gem of Facility"
msgstr "便利宝石"

msgid "desc_r_Gem of Facility"
msgstr "这种附魔将降低一块盔甲的惩戒."

msgid "r_Gem of Fire"
msgstr "火焰宝石"

msgid "desc_r_Gem of Fire"
msgstr "具有此附魔的武器将会造成额外的火系伤害."

msgid "r_Gem of Fire Magic"
msgstr "火魔法宝石"

msgid "desc_r_Gem of Fire Magic"
msgstr "具有此附魔的法杖将增加火元素魔法法术强度."

msgid "r_Gem of Fire Protection"
msgstr "火焰防护加成"

msgid "desc_r_Gem of Fire Protection"
msgstr "这种附魔将增加一块盔甲的火焰防护能力."

msgid "r_Gem of Fire Weakness"
msgstr "火焰弱点宝石"

msgid "desc_r_Gem of Fire Weakness"
msgstr "具有此附魔的武器除了造成伤害外,还会降低其目标的火焰防护能力."

msgid "r_Gem of Fortitude"
msgstr "毅力宝石"

msgid "desc_r_Gem of Fortitude"
msgstr "具有此附魔的物品会增强其佩带者的毅力.它可以被注入武器,盔甲或珠宝中."

msgid "r_Gem of Frost"
msgstr "冰霜宝石"

msgid "desc_r_Gem of Frost"
msgstr "具有此附魔的武器会造成额外的寒冷伤害."

msgid "r_Gem of Greater Magic"
msgstr "高级魔法宝石"

msgid "desc_r_Gem of Greater Magic"
msgstr "具有此附魔的法杖将增加所有高级魔法法术的强度."

msgid "r_Gem of Haste"
msgstr "急速宝石"

msgid "desc_r_Gem of Haste"
msgstr "具有此附魔的武器将提高该武器的攻击速度."

msgid "r_Gem of Health"
msgstr "生命宝石"

msgid "desc_r_Gem of Health"
msgstr "具有此附魔的物品将增加穿戴者的最大生命值.它可以被注入到武器,盔甲或珠宝中."

msgid "r_Gem of Health Gain"
msgstr "生命增益宝石"

msgid "desc_r_Gem of Health Gain"
msgstr "具有此附魔的物品将提高穿戴者的生命回复速度.它可以被注入盔甲或珠宝中."

msgid "r_Gem of Holy Protection"
msgstr "圣术防护宝石"

msgid "desc_r_Gem of Holy Protection"
msgstr "这种附魔将增加一块盔甲的圣术防护能力."

msgid "r_Gem of Humanbane"
msgstr "人类诅咒宝石"

msgid "desc_r_Gem of Humanbane"
msgstr "具有此附魔的武器将对人类造成额外伤害."

msgid "r_Gem of Impact"
msgstr "撞击宝石"

msgid "desc_r_Gem of Impact"
msgstr "具有此附魔的武器会造成额外的撞击伤害."

msgid "r_Gem of Impact Protection"
msgstr "撞击防护宝石"

msgid "desc_r_Gem of Impact Protection"
msgstr "这种附魔将增加一块盔甲的撞击防护能力."

msgid "r_Gem of Inaccuracy"
msgstr "模糊宝石"

msgid "desc_r_Gem of Inaccuracy"
msgstr "具有此附魔的武器除了造成伤害外,还会降低其目标的近战精确度."

msgid "r_Gem of Intelligence"
msgstr "智力宝石"

msgid "desc_r_Gem of Intelligence"
msgstr "具有此附魔的的物品会提高其佩带者的智力.具有此效果的多个物品不会叠加其加成."

msgid "r_Gem of Intelligence Drain"
msgstr "智力消耗宝石"

msgid "desc_r_Gem of Intelligence Drain"
msgstr " "

msgid "r_Gem of Knockdown"
msgstr "击倒宝石"

msgid "desc_r_Gem of Knockdown"
msgstr "具有此附魔的武器除了造成正常伤害之外,有时会造成击倒."

msgid "r_Gem of Lesser Magic"
msgstr "初级魔法宝石"

msgid "desc_r_Gem of Lesser Magic"
msgstr "具有此附魔的法杖将增加所有初级魔法法术的强度."

msgid "r_Gem of Lightning"
msgstr "闪电宝石"

msgid "desc_r_Gem of Lightning"
msgstr "具有此附魔的武器会造成额外的闪电伤害."

msgid "r_Gem of Lightning Protection"
msgstr "闪电防护宝石"

msgid "desc_r_Gem of Lightning Protection"
msgstr "这种附魔将增加一块盔甲的闪电防护能力."

msgid "r_Gem of Lightning Weakness"
msgstr "闪电弱点宝石"

msgid "desc_r_Gem of Lightning Weakness"
msgstr "具有此附魔的武器除了会造成伤害之外,还会对其目标造成闪电防护惩罚."

msgid "r_Gem of Mahirimbane"
msgstr "狼人诅咒宝石"

msgid "desc_r_Gem of Mahirimbane"
msgstr "具有此附魔的武器会对狼人造成额外的伤害."

msgid "r_Gem of Maiming"
msgstr "伤害宝石"

msgid "desc_r_Gem of Maiming"
msgstr "具有此附魔的武器除了造成伤害外,还会略微降低目标的最大生命值."

msgid "r_Gem of Malediction Protection"
msgstr "诅咒防护宝石"

msgid "desc_r_Gem of Malediction Protection"
msgstr "这种附魔将增加一块盔甲的诅咒防护能力."

msgid "r_Gem of Mana"
msgstr "法力宝石"

msgid "desc_r_Gem of Mana"
msgstr "具有此附魔的物品将增加其佩戴者的最大法力值.它可以被注入法杖或珠宝中."

msgid "r_Gem of Mana Drain"
msgstr "法力消耗宝石"

msgid "desc_r_Gem of Mana Drain"
msgstr "具有此附魔的武器除了造成伤害外,还会消耗目标的法力值."

msgid "r_Gem of Mana Gain"
msgstr "法力增益宝石"

msgid "desc_r_Gem of Mana Gain"
msgstr "具有此附魔的物品会提高其穿戴者的法力回复速度. 它可以被注入盔甲,珠宝或法杖中."

msgid "r_Gem of Mana Theft"
msgstr "法力偷窃宝石"

msgid "desc_r_Gem of Mana Theft"
msgstr "具有此附魔的武器除了会造成伤害外,还会降低其目标的法力值.此外,攻击者还将获得少量法力值."

msgid "r_Gem of Mental Protection"
msgstr "精神防护宝石"

msgid "desc_r_Gem of Mental Protection"
msgstr " "

msgid "r_Gem of Might"
msgstr "威力宝石"

msgid "desc_r_Gem of Might"
msgstr "具有此附魔的物品将增加其佩戴者的力量.它可以被注入到武器,盔甲或珠宝中."

msgid "r_Gem of Mind Assault"
msgstr "心灵攻击宝石"

msgid "desc_r_Gem of Mind Assault"
msgstr "具有此附魔的武器除了会造成伤害外,还会稍微降低其目标的最大法力值."

msgid "r_Gem of Mirdainbane"
msgstr "精灵诅咒宝石"

msgid "desc_r_Gem of Mirdainbane"
msgstr "具有此附魔的武器会对精灵造成额外的伤害."

msgid "r_Gem of Necromancy"
msgstr "死灵宝石"

msgid "desc_r_Gem of Necromancy"
msgstr "具有此附魔的法杖将增加所有死灵法术的强度."

msgid "r_Gem of Numbing"
msgstr "麻木宝石"

msgid "desc_r_Gem of Numbing"
msgstr "具有此附魔的武器除了造成伤害外,还可以阻挡其目标的所有特殊攻击."

msgid "r_Gem of Orkbane"
msgstr "兽人诅咒宝石"

msgid "desc_r_Gem of Orkbane"
msgstr "具有此附魔的武器会对兽人造成额外的伤害."

msgid "r_Gem of Piercing Protection"
msgstr "穿刺防护宝石"

msgid "desc_r_Gem of Piercing Protection"
msgstr "这种附魔将增加一块盔甲的穿刺防护能力."

msgid "r_Gem of Piercing Weakness"
msgstr "穿刺弱点宝石"

msgid "desc_r_Gem of Piercing Weakness"
msgstr "具有此附魔的武器除了造成伤害外,还会降低其目标的穿刺防护."

msgid "r_Gem of Punishment"
msgstr "惩罚宝石"

msgid "desc_r_Gem of Punishment"
msgstr " 具有此附魔的武器除了会造成伤害外,还会略微降低其目标的最大耐力值."

msgid "r_Gem of Quick Casting"
msgstr "快速施法宝石"

msgid "desc_r_Gem of Quick Casting"
msgstr "这种附魔减少了施放各种魔法所需的时间."

msgid "r_Gem of Quickness"
msgstr "敏捷宝石"

msgid "desc_r_Gem of Quickness"
msgstr "具有此附魔的物品会提高其佩带者的敏捷度.具有此效果的多个物品不会叠加其加成."

msgid "r_Gem of Quickness Drain"
msgstr "敏捷消耗宝石"

msgid "desc_r_Gem of Quickness Drain"
msgstr " "

msgid "r_Gem of Rending"
msgstr "撕裂宝石"

msgid "desc_r_Gem of Rending"
msgstr "附有此宝石的武器会造成额外的流血伤害."

msgid "r_Gem of Righteousness"
msgstr "正义宝石"

msgid "desc_r_Gem of Righteousness"
msgstr "具有此附魔的武器将造成额外的神圣伤害."

msgid "r_Gem of Ritual Magic"
msgstr "仪式魔法宝石"

msgid "desc_r_Gem of Ritual Magic"
msgstr "具有此附魔的法杖将增加所有仪式法术的强度.只有施法的人才能增加这种加成."

msgid "r_Gem of Sharpness"
msgstr "锐利宝石"

msgid "desc_r_Gem of Sharpness"
msgstr "被注入此附魔的武器将增加暴击得分."

msgid "r_Gem of Silence"
msgstr "沉默宝石"

msgid "desc_r_Gem of Silence"
msgstr "具有此附魔的武器除了造成伤害外,还可以阻挡目标的所有施法."

msgid "r_Gem of Slashing Protection"
msgstr "剑伤防护宝石"

msgid "desc_r_Gem of Slashing Protection"
msgstr "具有此附魔的物品将增加穿戴者的剑伤防护.只有盔甲和珠宝可以注入."

msgid "r_Gem of Slashing Weakness"
msgstr "剑伤弱点宝石"

msgid "desc_r_Gem of Slashing Weakness"
msgstr "具有此附魔的武器除了造成伤害外,还会降低目标的剑伤防护."

msgid "r_Gem of Speed"
msgstr "速度宝石"

msgid "desc_r_Gem of Speed"
msgstr "具有此附魔的珠宝将提高佩戴者的移动速度."

msgid "r_Gem of Spell Chanting"
msgstr "法术吟唱宝石"

msgid "desc_r_Gem of Spell Chanting"
msgstr "具有此附魔的法杖将增加所有吟唱法术的强度."

msgid "r_Gem of Spell Delay"
msgstr "法术延迟宝石"

msgid "desc_r_Gem of Spell Delay"
msgstr "具有此附魔的武器除了造成伤害外,还可以增加目标的施法时间."

msgid "r_Gem of Stamina"
msgstr "耐力宝石"

msgid "desc_r_Gem of Stamina"
msgstr "具有此附魔的物品将增加佩戴者的最大耐力值.它可以被注入到武器,盔甲或珠宝中."

msgid "r_Gem of Stamina Drain"
msgstr "耐力消耗宝石"

msgid "desc_r_Gem of Stamina Drain"
msgstr "具有此附魔的武器除了造成伤害外,还会降低目标的耐力."

msgid "r_Gem of Stamina Gain"
msgstr "耐力增益宝石"

msgid "desc_r_Gem of Stamina Gain"
msgstr "具有此附魔的物品将增加穿戴者的法力回复速度.它可以被注入到盔甲或珠宝中."

msgid "r_Gem of Stamina Theft"
msgstr "耐力偷窃宝石"

msgid "desc_r_Gem of Stamina Theft"
msgstr "具有此附魔的武器除了造成伤害外,还会降低目标的耐力.同时,它将稍微增加攻击者的耐力."

msgid "r_Gem of Stealth"
msgstr "隐形宝石"

msgid "desc_r_Gem of Stealth"
msgstr "具有此附魔的物品将给予穿戴者潜行技能加成.它可以被注入盔甲或珠宝中."

msgid "r_Gem of Strength"
msgstr "力量宝石"

msgid "desc_r_Gem of Strength"
msgstr "具有此附魔的物品会提高其佩带者的力量值.具有此效果的多个物品不会叠加其加成."

msgid "r_Gem of Strength Drain"
msgstr "力量消耗宝石"

msgid "desc_r_Gem of Strength Drain"
msgstr "具有此附魔的武器除了造成伤害之外还会降低其目标的力量."

msgid "r_Gem of the Feather"
msgstr "羽毛宝石"

msgid "desc_r_Gem of the Feather"
msgstr "这种附魔可以减轻物体的重量.它可能不会使其降低到零以下."

msgid "r_Gem of the Inferno"
msgstr "地狱宝石"

msgid "desc_r_Gem of the Inferno"
msgstr "具有此附魔的武器造成额外的邪恶伤害."

