msgid "r_Leensword"
msgstr "红炎剑"

msgid "desc_r_Leensword"
msgstr "最初的红炎剑是由月亮女神的崇拜者在Agon第二轮月亮的红光中锻造的."

msgid "r_Lightbringer"
