msgid "finished_text_quest_3355"
msgstr ""
"Has matado con éxito 200 Espectros y 10 Señores de Roble, y ganaste el "
"derecho al título de The Tough. Regresa a Sandra la Arcanista y reclama tus "
"recompensas y tu título de logro."

msgid "finished_text_quest_3357"
msgstr ""
"Has matado exitosamente 200 Akathars. Vuelve a Simeon el Comerciante en "
"Sanguine y recoge tu recompensa."

msgid "finished_text_quest_3359"
msgstr "Has alcanzado a Edwin el Comerciante."

msgid "finished_text_quest_3361"
msgstr ""
